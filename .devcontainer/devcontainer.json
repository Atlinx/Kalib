{
    "name": "Kalib - Hand-Eye Calibration",
    "dockerFile": "../Dockerfile",
    "workspaceMount": "type=bind,consistency=cached,source=${localWorkspaceFolder},target=/home/developer/Kalib", // Mount local repo
    "workspaceFolder": "/home/developer/Kalib",
    "mounts": [
        "type=volume,dst=/home/developer/Kalib/third_party" // Hide third_party, to use the prebuild versions in the image
    ],
    "remoteUser": "developer",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "ms-python.black-formatter"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/opt/conda/envs/kalib/bin/python",
                "python.linting.enabled": true,
                "python.linting.pylintEnabled": true,
                "python.formatting.provider": "black",
                "[python]": {
                    "editor.defaultFormatter": "ms-python.python",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.organizeImports": "explicit"
                    }
                }
            }
        }
    },
    "forwardPorts": []
}
